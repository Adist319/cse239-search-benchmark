# Copy to .env and fill in values
# cp .env.example .env

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=search_bench
POSTGRES_USER=bench
POSTGRES_PASSWORD=benchpass

# Dataset to benchmark (fiqa | trec-covid | nfcorpus | scifact | scidocs | quora | msmarco)
DATASET_NAME=fiqa

# Set > 0 to limit corpus size (useful for development)
DATASET_LIMIT=0

# Benchmark parameters
N_WARMUP=10
N_RUNS=5
K=10
EF_SEARCH=100
RRF_K=60
RRF_POOL=20

# Embedding batch size (64 for CPU, 256 for GPU)
EMBEDDING_BATCH=64
